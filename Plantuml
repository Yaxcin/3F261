@startuml
class Usuario {
    + Jugar(Mario)
}

class Mario {
    + Viajar(Tuberia)
    + Comer(Item)
    - vida
}

class Luigi {
    + Comer(Item)
    - vida
}

class Personaje {
    - salud
    + Morir()
    + Moverse()
}

class Enemigo {
    - vida
    + Atacar()
    + Morir()
}

class Goomba {
    + Morir()
}

class Koopa {
    - Vida vida
    + Morir()
}

class Bowser {
    - poder
    + LanzarFuego()
    + Morir()
}

class Bulletbill {
    + Morir()
}

class Plantapiraña {
    + Atacar()
    + Morir()
}

class Spiny {
    + Morir()
}

class Paratroopa {
    + Volar()
    + Morir()
}

class Lakitu {
    + LanzarSpiny()
}

class Cheep {
    + Nadar()
}

class NPC {
    + Interactuar()
}

class Item {
    + Usar()
}

class Champiñon {
    + Usar()
}

class Fireflower {
    + Usar()
}

class Estrella {
    + Usar()
}

class Moneda {
    + Usar()
}

class Hongo {
    + Usar()
}

class Fuego {
    + Usar()
}

class Fireball {
    + Usar()
}

class Bloque {
    - contenido
    + Explotar() : Item
}

class Plataforma {
    + Soportar()
}

class Tuberia {
    + Transportar()
}

class Caparazon {
    + Usar()
}

class Vida {
    - cantidad
}

class Daño {
    - cantidad
}

class Estructura {
    + Entrar()
}

class Castillo {
    + Entrar()
}

class Asta {
    + Escalar()
}

class Bandera {
    + Capturar()
}

Usuario o-- Mario
Mario --|> Personaje
Luigi --|> Personaje
Mario *-- Vida
Luigi *-- Vida
Mario *-- Daño
Luigi *-- Daño
Mario o-- Champiñon
Luigi o-- Champiñon
Mario o-- Fireflower
Luigi o-- Fireflower
Mario o-- Estrella
Luigi o-- Estrella
Mario o-- Moneda
Luigi o-- Moneda
Mario o-- Tuberia
Luigi o-- Tuberia
Mario o-- Fuego
Luigi o-- Fuego
Mario o-- Fireball
Luigi o-- Fireball
Mario o-- Bloque
Bowser --|> Enemigo
Goomba --|> Enemigo
Koopa --|> Enemigo
Koopa *-- Caparazon
Paratroopa *-- Caparazon
Paratroopa --|> Enemigo
Bulletbill --|> Enemigo
Plantapiraña --|> Enemigo
Spiny --|> Enemigo
Lakitu --|> NPC
Cheep --|> NPC
Champiñon --|> Item
Fireflower --|> Item
Estrella --|> Item
Moneda --|> Item
Hongo --|> Item
Fuego --|> Item
Fireball --|> Item
Bloque *-- Item
Plataforma --|> Bloque
Castillo --|> Estructura
Asta *-- Bandera

@enduml